rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Multi-user layout: Users can only access their own network nodes
    match /users/{userId}/network_nodes/{nodeId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Multi-user layout: Users can only access their own scanner controls
    match /users/{userId}/scanner_control/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
